server {
    listen 80;
    server_name tax.contexta.biz;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name tax.contexta.biz;

    # Replace with your real certificate paths
    ssl_certificate /etc/letsencrypt/live/tax.contexta.biz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/tax.contexta.biz/privkey.pem;

    root /var/www/tax.contexta.biz;
    index index.html;

    # Static landing page at the root for SEO / OG / Twitter previews
    location = / {
        try_files /index.html =404;
    }

    # Static OG image
    location = /canadian-income-tax-estimator-og.jpg {
        try_files /canadian-income-tax-estimator-og.jpg =404;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
    }

    # Optional other static assets
    location /assets/ {
        try_files $uri =404;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
    }

    # Streamlit app behind /app/
    location /app/ {
        proxy_pass http://127.0.0.1:8501/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400;
    }
}
